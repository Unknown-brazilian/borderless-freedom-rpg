; ── Hierarquia ────────────────────────────────────────────────────────────────
;
;  DeportationChallenge (CanvasLayer layer=40, hidden)
;  └── MainPanel (PanelContainer, full screen minus margins)
;      └── MainVBox
;          ├── WarningBox / LabelWarning
;          ├── LabelPrompt
;          ├── LabelProgress
;          ├── SelectedPanel → LabelSelected
;          ├── ScrollContainer → WordGrid (GridContainer 3 colunas)
;          ├── LabelResult (hidden)
;          └── HBoxButtons → ButtonConfirm + ButtonUndo

[node name="DeportationChallenge" type="CanvasLayer"]
layer  = 40
script = ExtResource("1_dep_script")

[node name="MainPanel" type="PanelContainer" parent="."]
anchor_left   = 0.0
anchor_right  = 1.0
anchor_top    = 0.0
anchor_bottom = 1.0
offset_left   = 16.0
offset_right  = -16.0
offset_top    = 16.0
offset_bottom = -16.0
theme_override_styles/panel = SubResource("StyleBoxFlat_panel")

[node name="MainVBox" type="VBoxContainer" parent="MainPanel"]
layout_mode                         = 2
theme_override_constants/separation = 14

[node name="WarningBox" type="PanelContainer" parent="MainPanel/MainVBox"]
layout_mode                 = 2
theme_override_styles/panel = SubResource("StyleBoxFlat_warning")

[node name="LabelWarning" type="Label" parent="MainPanel/MainVBox/WarningBox"]
layout_mode                         = 2
text                                = "⚠️  SEED DO JOGO — NUNCA TOQUE SEEDS REAIS COM SALDO EM NENHUM APP."
horizontal_alignment                = 1
autowrap_mode                       = 3
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color    = Color(1.0, 0.85, 0.85, 1.0)

[node name="LabelPrompt" type="Label" parent="MainPanel/MainVBox"]
layout_mode                         = 2
text                                = "🔐  DEPORTAÇÃO — VERIFICAÇÃO FINAL\nToque as 24 palavras na ordem certa."
horizontal_alignment                = 1
autowrap_mode                       = 3
theme_override_font_sizes/font_size = 26
theme_override_colors/font_color    = Color(0.969, 0.576, 0.102, 1.0)

[node name="LabelProgress" type="Label" parent="MainPanel/MainVBox"]
layout_mode                         = 2
text                                = "0 / 24 palavras selecionadas"
horizontal_alignment                = 1
theme_override_font_sizes/font_size = 23
theme_override_colors/font_color    = Color(0.6, 0.75, 1.0, 1.0)

[node name="SelectedPanel" type="PanelContainer" parent="MainPanel/MainVBox"]
layout_mode                 = 2
custom_minimum_size         = Vector2(0, 78)
theme_override_styles/panel = SubResource("StyleBoxFlat_selected")

[node name="LabelSelected" type="Label" parent="MainPanel/MainVBox/SelectedPanel"]
layout_mode                         = 2
text                                = "(nenhuma ainda)"
horizontal_alignment                = 1
autowrap_mode                       = 3
theme_override_font_sizes/font_size = 21
theme_override_colors/font_color    = Color(0.85, 0.85, 1.0, 1.0)

[node name="ScrollContainer" type="ScrollContainer" parent="MainPanel/MainVBox"]
layout_mode         = 2
custom_minimum_size = Vector2(0, 680)
size_flags_vertical = 3

[node name="WordGrid" type="GridContainer" parent="MainPanel/MainVBox/ScrollContainer"]
layout_mode                           = 2
size_flags_horizontal                 = 3
columns                               = 3
theme_override_constants/h_separation = 8
theme_override_constants/v_separation = 8

[node name="LabelResult" type="Label" parent="MainPanel/MainVBox"]
layout_mode                         = 2
visible                             = false
text                                = ""
horizontal_alignment                = 1
autowrap_mode                       = 3
theme_override_font_sizes/font_size = 27
theme_override_colors/font_color    = Color(0.2, 0.9, 0.2, 1.0)

[node name="HBoxButtons" type="HBoxContainer" parent="MainPanel/MainVBox"]
layout_mode                         = 2
theme_override_constants/separation = 14

[node name="ButtonConfirm" type="Button" parent="MainPanel/MainVBox/HBoxButtons"]
layout_mode                         = 2
size_flags_horizontal               = 3
custom_minimum_size                 = Vector2(0, 80)
text                                = "✅  CONFIRMAR ORDEM"
theme_override_font_sizes/font_size = 27
theme_override_colors/font_color    = Color(0.969, 0.576, 0.102, 1.0)
theme_override_styles/normal        = SubResource("StyleBoxFlat_btn")
theme_override_styles/hover         = SubResource("StyleBoxFlat_btn")
theme_override_styles/pressed       = SubResource("StyleBoxFlat_btn")

[node name="ButtonUndo" type="Button" parent="MainPanel/MainVBox/HBoxButtons"]
layout_mode                         = 2
custom_minimum_size                 = Vector2(170, 80)
text                                = "↩  DESFAZER"
theme_override_font_sizes/font_size = 25
theme_override_colors/font_color    = Color(0.7, 0.7, 0.7, 1.0)
theme_override_styles/normal        = SubResource("StyleBoxFlat_btn")
theme_override_styles/hover         = SubResource("StyleBoxFlat_btn")
theme_override_styles/pressed       = SubResource("StyleBoxFlat_btn")
